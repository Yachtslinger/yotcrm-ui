  const m = title.match(/(\d+)\s*(?:ft|')?\s*(\d{4})\s+(.+)/i) || title.match(/(\d{4})\s+(.+?)(?:\s*\|\s*(\d+)ft)?$/);
  let year = '', makeModel = '', length = '';
  if (m && m[1] && m[1].length === 4) { year = m[1]; makeModel = m[2] || title; length = m[3] ? `${m[3]} ft` : ''; }
  else if (m) { length = m[1] ? `${m[1]} ft` : ''; year = m[2] || ''; makeModel = m[3] || title; }
  else { makeModel = title; }
  if (!length) { const lm = spec(s, 'Length Overall', 'LOA'); if (lm) length = lm; }
  
  const boatName = data.boatName || spec(s, 'Name') || '';
