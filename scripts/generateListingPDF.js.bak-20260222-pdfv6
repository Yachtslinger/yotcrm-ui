// --- GARBAGE VALUE FILTER ---
const GARBAGE_VALUES = new Set(['boats', 'tank:', 'tank', 'n/a', 'na', 'none', '-', '--', 'overall:', 'unknown']);
function isGarbage(val) {
  if (!val || typeof val !== 'string') return true;
  const v = val.trim().toLowerCase();
  return GARBAGE_VALUES.has(v) || v.length === 0;
}
function cleanVal(val) {
  if (!val || typeof val !== 'string') return '';
  let v = val.trim();
  // Remove leading "Tank:" or similar prefixes that are labels not values
  v = v.replace(/^tank:\s*/i, '').trim();
  if (isGarbage(v)) return '';
  return v;
}

// --- SPEC LOOKUP with flexible key matching ---
function spec(specs, ...keys) {
  if (!specs) return '';
  // Exact match first
  for (const k of keys) {
    if (specs[k] !== undefined && specs[k] !== null && specs[k] !== '') {
      const v = cleanVal(String(specs[k]));
      if (v) return v;
    }
  }
  // Case-insensitive + stripped colon/whitespace search
  const normalize = s => s.toLowerCase().replace(/[:\s]+/g, '').replace(/[_-]/g, '');
  for (const k of keys) {
    const nk = normalize(k);
    const found = Object.entries(specs).find(([sk]) => normalize(sk) === nk);
    if (found) { const v = cleanVal(String(found[1])); if (v) return v; }
  }
  // Partial match as last resort
  for (const k of keys) {
    const lk = k.toLowerCase();
    const found = Object.entries(specs).find(([sk]) => {
      const slk = sk.toLowerCase();
      return slk.includes(lk) || lk.includes(slk);
    });
    if (found) { const v = cleanVal(String(found[1])); if (v) return v; }
  }
  return '';
}

function filterImages(images, listingUrl) {
  let listingId = null;
  if (listingUrl) {
    const m = listingUrl.match(/(\d{5,})(?:\/)?(?:\?.*)?$/);
    if (m) listingId = m[1];
  }
  if (!listingId) {
    const idCounts = {};
    images.forEach(img => {
      if (img.url && img.url.includes('boatsgroup.com')) {
        const m = img.url.match(/(\d{7,})/);
        if (m) idCounts[m[1]] = (idCounts[m[1]] || 0) + 1;
      }
    });
    const sorted = Object.entries(idCounts).sort((a, b) => b[1] - a[1]);
    if (sorted.length > 0 && sorted[0][1] >= 3) listingId = sorted[0][0];
  }
  return images.filter(img => {
    if (!img.localPath || !fs.existsSync(img.localPath)) return false;
    const sz = fs.statSync(img.localPath).size;
    if (sz < 10000) return false;
    if (img.url && img.url.includes('servedby')) return false;
    if (listingId && img.url && img.url.includes('boatsgroup.com') && !img.url.includes(listingId)) return false;
    return true;
  });
}

function brokerFooterHTML(mode) {
  const brokers = mode === 'both' ? [BROKERS.will, BROKERS.paolo] :
                  mode === 'paolo' ? [BROKERS.paolo] : [BROKERS.will];
  const cards = brokers.map(b => `
    <div class="broker-card">
      <div class="broker-photo">
        ${b.photo ? `<img src="${b.photo}" />` : `<div style="width:100%;height:100%;background:#ccc"></div>`}
      </div>
      <div class="broker-info">
        <h3>${b.name} | <span class="co">${b.company}</span></h3>
        <p>${b.address}<br/>Tel: <span class="ph">${b.phone}</span>&nbsp;&nbsp;Fax: ${b.fax}<br/>${b.email}</p>
      </div>
    </div>
  `).join('');
  return `
    <div class="broker-footer">
      <div class="broker-cards ${mode === 'both' ? 'two-brokers' : ''}">${cards}</div>
      <div class="broker-denison">${LOGO.denison ? `<img src="${LOGO.denison}" />` : ''}</div>
    </div>`;
}

// --- SMART DESCRIPTION FORMATTING ---
function formatDescription(rawText) {
  if (!rawText || rawText.length < 50) return '';
  
  const lines = rawText.split('\n');
  let html = '';
  let inList = false;
  
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i].trim();
    if (!line) {
      if (inList) { html += '</ul>'; inList = false; }
      continue;
    }
    
    // Detect section headers: ALL CAPS lines, or short lines followed by details
    const isAllCaps = line === line.toUpperCase() && line.length > 3 && line.length < 80 && /[A-Z]/.test(line);
    const nextLine = i + 1 < lines.length ? lines[i + 1]?.trim() : '';
    const isFollowedByContent = nextLine && nextLine.length > 0;
    
    if (isAllCaps && isFollowedByContent) {
      if (inList) { html += '</ul>'; inList = false; }
      const titleCased = line.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' ');
      html += `<h3>${titleCased}</h3>`;
      continue;
    }
    
    // Detect bullet points
    const bulletMatch = line.match(/^[-•*]\s+(.+)/) || line.match(/^\(\d+\)\s+(.+)/) || line.match(/^\d+[.)]\s+(.+)/);
    if (bulletMatch) {
      if (!inList) { html += '<ul>'; inList = true; }
      html += `<li>${bulletMatch[1]}</li>`;
      continue;
    }
    
    // Regular paragraph text
    if (inList) { html += '</ul>'; inList = false; }
    html += `<p>${line}</p>`;
  }
  if (inList) html += '</ul>';
  
  return html;
}

function fullDescription(data) {
  const s = data.specs || {};

  // If the scraper got a real description (more than ~50 chars), use it with smart formatting
  if (data.description && data.description.trim().length > 50) {
    const formatted = formatDescription(data.description);
    if (formatted) return formatted;
    // Fallback: simple paragraph rendering preserving breaks
    return `<p>${data.description.replace(/\n{2,}/g, '</p><p>').replace(/\n/g, '<br/>')}</p>`;
  }

  // Otherwise build a summary from specs
  const n = data.boatName || spec(s, 'Name') || 'This vessel';
  const yr = data.title?.match(/(\d{4})/)?.[1] || '';
  const hull = spec(s, 'Hull Material', 'Hull', 'Hull Construction') || '';
  const beam = spec(s, 'Beam') || '';
  const hrs = spec(s, 'Engine Hours') || '';
  const cs = spec(s, 'Cruising Speed') || '';
  const ms = spec(s, 'Max Speed') || '';
  const rng = spec(s, 'Range') || '';
  const gc = spec(s, 'Guest Cabins') || '';
  const cc = spec(s, 'Crew Cabins') || '';

  let d = `<p><strong>${n}</strong> is a ${yr}`;
  if (beam) d += ` with a beam of ${beam}`;
  d += `.</p>`;

  if (hrs || cs || ms || rng) {
    d += `<h3>Performance</h3><p>`;
    if (hrs) d += `(${hrs} hours)`;
    if (cs) d += `Cruising speed: ${cs}. `;
    if (ms) d += `Max speed: ${ms}. `;
    if (rng) d += `Range: ${rng}. `;
    d += `</p>`;
  }
  if (gc || cc) {
    d += `<h3>Accommodation</h3><p>`;
    if (gc) d += `${gc} guest cabin${gc !== '1' ? 's' : ''}`;
    if (cc) d += ` and ${cc} crew cabin${cc !== '1' ? 's' : ''}`;
    d += `.</p>`;
  }
  if (hull) {
    d += `<h3>Build</h3><p>${hull} hull.</p>`;
  }
  return d;
}

// --- ENGINE DATA EXTRACTION ---
function extractEngineData(data) {
  const s = data.specs || {};
  
  // Try to get engine name from various fields
  let engineName = spec(s, 'Main Engines (2)', 'Main Engines', 'Main Engine', 'Engine Make', 'Engine Brand', 'Engines');
  // Filter out garbage
  if (engineName && (engineName.toLowerCase() === 'boats' || engineName.length < 3)) engineName = '';
  
  const engineType = spec(s, 'Engine Type', 'Drive Type', 'Propulsion') || 'Inboard';
  const fuelType = spec(s, 'Fuel Type', 'Engine Fuel') || 'Diesel';
  
  // Engine hours - try specific engine fields first
  let hours1 = spec(s, 'Engine 1 Hours', 'Port Engine Hours', 'Engine Hours');
  let hours2 = spec(s, 'Engine 2 Hours', 'Stbd Engine Hours', 'Starboard Engine Hours');
  if (!hours2) hours2 = hours1; // If only one hours field, use for both
  
  // Power
  let power = spec(s, 'Power', 'Engine Power', 'HP', 'Horsepower', 'Total Power');
  // Filter garbage power values
  if (power && (power.toLowerCase() === 'boats' || power.length < 2)) power = '';
  
  // Build engine card titles
  let eng1Title = 'Engine (Engine 1)';
  let eng2Title = 'Engine (Engine 2)';
  if (engineName) {
    eng1Title = `${engineName} (Port)`;
    eng2Title = `${engineName} (Stbd)`;
  }
  
  return {
    eng1Title, eng2Title,
    engineType, fuelType,
    hours1, hours2,
    power, engineName,
  };
}

function buildHTML(data, listingDir, brokerMode, logoMode) {
