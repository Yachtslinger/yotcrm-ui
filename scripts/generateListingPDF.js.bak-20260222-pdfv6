    </div>
    <div class="engine-card">
      <h3>${engines.eng2Title}</h3>
      <table class="detail-table">
        <tr><td>Engine Type:</td><td>${engines.engineType}</td></tr>
        <tr><td>Fuel Type:</td><td>${engines.fuelType}</td></tr>
        <tr><td>Engine Hours:</td><td>${engines.hours2}</td></tr>
        ${engines.power ? `<tr><td>Power:</td><td>${engines.power}</td></tr>` : ''}
      </table>
    </div>
  </div>
  <div class="specs-grid">
    <div class="spec-card"><h3>Dimensions</h3><table class="detail-table">
      <tr><td>LOA:</td><td>${spec(s, 'Length Overall', 'LOA') || length}</td></tr>
      <tr><td>Beam:</td><td>${spec(s, 'Beam')}</td></tr>
      <tr><td>Max Draft:</td><td>${draft}</td></tr>
    </table></div>
    <div class="spec-card"><h3>Weights</h3><table class="detail-table">
      <tr><td>Displacement:</td><td>${displacement}</td></tr>
      <tr><td>Gross Tonnage:</td><td>${grossTonnage}</td></tr>
    </table></div>
    <div class="spec-card"><h3>Speed &amp; Range</h3><table class="detail-table">
      <tr><td>Cruising Speed:</td><td>${spec(s, 'Cruising Speed')}</td></tr>
      <tr><td>Max Speed:</td><td>${spec(s, 'Max Speed')}</td></tr>
      <tr><td>Range:</td><td>${spec(s, 'Range')}</td></tr>
    </table></div>
    <div class="spec-card"><h3>Tanks</h3><table class="detail-table">
      <tr><td>Fuel:</td><td>${fuelCap}</td></tr>
      <tr><td>Fresh Water:</td><td>${freshWater}</td></tr>
      <tr><td>Holding:</td><td>${holding}</td></tr>
      ${greyWater ? `<tr><td>Grey Water:</td><td>${greyWater}</td></tr>` : ''}
    </table></div>
    <div class="spec-card"><h3>Accommodations</h3><table class="detail-table">
      <tr><td>Guest Cabins:</td><td>${spec(s, 'Guest Cabins')}</td></tr>
      <tr><td>Crew Cabins:</td><td>${spec(s, 'Crew Cabins')}</td></tr>
      <tr><td>Guest Heads:</td><td>${spec(s, 'Guest Heads')}</td></tr>
      <tr><td>Crew Heads:</td><td>${spec(s, 'Crew Heads')}</td></tr>
    </table></div>
    <div class="spec-card"><h3>Electrical Equipment</h3><table class="detail-table">
      <tr><td>Generator:</td><td>${generator}</td></tr>
      ${emergGen ? `<tr><td>Emergency:</td><td>${emergGen}</td></tr>` : ''}
      ${watermaker ? `<tr><td>Watermaker:</td><td>${watermaker}</td></tr>` : ''}
    </table></div>
    <div class="spec-card"><h3>Construction</h3><table class="detail-table">
      <tr><td>Hull Shape:</td><td>${hullShape}</td></tr>
      <tr><td>Hull Material:</td><td>${hullMaterial}</td></tr>
      ${superstructure ? `<tr><td>Superstructure:</td><td>${superstructure}</td></tr>` : ''}
      <tr><td>Flag:</td><td>${flag}</td></tr>
      <tr><td>Builder:</td><td>${make}</td></tr>
      ${classification ? `<tr><td>Classification:</td><td>${classification}</td></tr>` : ''}
    </table></div>
    <div class="spec-card"><h3>Systems</h3><table class="detail-table">
      <tr><td>Stabilizers:</td><td>${stabilizers}</td></tr>
      <tr><td>Bow Thruster:</td><td>${bowThruster}</td></tr>
      <tr><td>Steering:</td><td>${steering}</td></tr>
      <tr><td>A/C:</td><td>${ac}</td></tr>
      ${gearboxes ? `<tr><td>Gearboxes:</td><td>${gearboxes}</td></tr>` : ''}
      ${windlass ? `<tr><td>Windlass:</td><td>${windlass}</td></tr>` : ''}
    </table></div>
    ${(radar || compass || ais || vhf) ? `
    <div class="spec-card"><h3>Navigation</h3><table class="detail-table">
      ${radar ? `<tr><td>Radar:</td><td>${radar}</td></tr>` : ''}
      ${compass ? `<tr><td>Compass:</td><td>${compass}</td></tr>` : ''}
      ${ais ? `<tr><td>AIS:</td><td>${ais}</td></tr>` : ''}
      ${vhf ? `<tr><td>VHFs:</td><td>${vhf}</td></tr>` : ''}
    </table></div>` : ''}
  </div>
</div>`;

  // === PHOTO GALLERY (6 per page, 3 rows x 2 cols, NO logo on middle pages) ===
  let galleryHTML = '';
  const galleryImages = allImages.slice(1); // skip hero
  let pageNum = 4; // cover=1, desc=2, specs=3

  for (let i = 0; i < galleryImages.length; i += 6) {
    const pg = galleryImages.slice(i, i + 6);
    // Skip pages with only 1 orphan image
    if (pg.length < 2) continue;
    
    const rows = [];
    for (let j = 0; j < 6; j += 2) {
      const img1 = pg[j];
      const img2 = pg[j + 1];
      let cells = '';
      if (img1) {
        cells += `<div class="gallery-cell"><img src="${imgB64(img1.localPath)}" /></div>`;
      } else {
        cells += `<div class="gallery-cell empty"></div>`;
      }
      if (img2) {
        cells += `<div class="gallery-cell"><img src="${imgB64(img2.localPath)}" /></div>`;
      } else {
        cells += `<div class="gallery-cell empty"></div>`;
      }
      // Only add row if at least one image exists
      if (img1 || img2) {
        rows.push(`<div class="gallery-row">${cells}</div>`);
      }
    }
    
    galleryHTML += `<div class="page photo-page">${rows.join('')}<div class="page-num">${pageNum}</div></div>`;
    pageNum++;
  }

  // Add selected logo to the last page (gallery or specs)
  const lastPageLogo = selectedLogo ? `
<div class="last-page-logo">
  <img src="${selectedLogo}" />
</div>` : '';

  // Inject logo before the last page-num div of the last gallery page
  if (galleryHTML) {
    const lastPageNumIdx = galleryHTML.lastIndexOf('<div class="page-num">');
    if (lastPageNumIdx > -1) {
      galleryHTML = galleryHTML.substring(0, lastPageNumIdx) + lastPageLogo + galleryHTML.substring(lastPageNumIdx);
    }
  }

  return `<!DOCTYPE html><html><head><meta charset="utf-8"><style>${css}${css2}${css3}</style></head><body>
${page1}${descPages}${specsPage}${galleryHTML}
</body></html>`;
}

async function generatePDF(listingDir, brokerMode, logoMode) {
  console.log(`📄 Generating PDF for: ${listingDir}`);
  console.log(`👤 Broker: ${brokerMode} | 🏷️ Logo: ${logoMode}`);
  
  const jsonPath = path.join(listingDir, 'listing.json');
  if (!fs.existsSync(jsonPath)) throw new Error(`No listing.json in ${listingDir}`);
  const data = JSON.parse(fs.readFileSync(jsonPath, 'utf8'));
  
  const html = buildHTML(data, listingDir, brokerMode, logoMode);
  fs.writeFileSync(path.join(listingDir, 'listing.html'), html);
  console.log(`📝 HTML saved`);
  
  const browser = await puppeteer.launch({
    headless: 'new',
    executablePath: process.env.PUPPETEER_EXECUTABLE_PATH || undefined,
    args: ['--no-sandbox', '--disable-setuid-sandbox', '--disable-dev-shm-usage'],
  });
  
  try {
    const page = await browser.newPage();
    await page.setContent(html, { waitUntil: 'networkidle0', timeout: 60000 });
    
    const suffix = brokerMode !== 'will' ? `-${brokerMode}` : '';
    const pdfName = path.basename(listingDir) + suffix + '.pdf';
    const pdfPath = path.join(listingDir, pdfName);
    
    await page.pdf({
      path: pdfPath,
      format: 'A4',
      printBackground: true,
      preferCSSPageSize: true,
      margin: { top: 0, right: 0, bottom: 0, left: 0 },
    });
    
    const sz = fs.statSync(pdfPath).size;
    console.log(`\n✅ PDF Generated: ${pdfPath}`);
    console.log(`📊 Size: ${(sz / 1024 / 1024).toFixed(1)} MB`);
    return pdfPath;
  } finally {
    await browser.close();
  }
}

// --- CLI ---
const args = process.argv.slice(2);
const listingDir = args.find(a => !a.startsWith('--'));
const brokerArg = args.find(a => a.startsWith('--broker='));
const brokerMode = brokerArg ? brokerArg.split('=')[1] : 'will';
const logoArg = args.find(a => a.startsWith('--logo='));
const logoMode = logoArg ? logoArg.split('=')[1] : 'slinger';

if (!listingDir) {
  console.log('Usage: node generateListingPDF.js <listing-dir> [--broker=will|paolo|both] [--logo=slinger|denison]');
  process.exit(1);
}
if (!['will', 'paolo', 'both'].includes(brokerMode)) {
  console.error('Invalid broker. Use: will, paolo, or both');
  process.exit(1);
}
if (!['slinger', 'denison'].includes(logoMode)) {
  console.error('Invalid logo. Use: slinger or denison');
  process.exit(1);
}

generatePDF(path.resolve(listingDir), brokerMode, logoMode).catch(err => {
  console.error('❌ Failed:', err.message);
  process.exit(1);
});
